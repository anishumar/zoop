# Server Configuration
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS="*" # In production, set to your frontend domain (e.g., https://app.example.com)
LOG_LEVEL=info

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/zoop_live?schema=public"

# Auth
JWT_SECRET="your-secret-key-here"

# Cloudflare R2 (S3-compatible)
R2_BUCKET="zoop-assets"
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY="your-r2-access-key"
R2_SECRET_KEY="your-r2-secret-key"
R2_PUBLIC_URL="https://pub-xxxx.r2.dev"

# LiveKit — self-hosted or LiveKit Cloud
LIVEKIT_API_KEY="devkey"
LIVEKIT_API_SECRET="secret"
LIVEKIT_URL="ws://localhost:7880"
LIVEKIT_WEBHOOK_KEY=""

# Gemini AI
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
